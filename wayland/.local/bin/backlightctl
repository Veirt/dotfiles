#!/bin/sh

if [ "$1" = "up" ]; then
    brightnessctl set 5%+
elif [ "$1" = "down" ]; then
    brightnessctl set 5%-
fi

BACKLIGHT=$(brightnessctl info | grep -oP '(?<=\()\d+\%(?=\))')

notify-send.sh "Backlight ${BACKLIGHT}" \
    --replace-file=/tmp/brightness-notification \
    -t 2000 \
    --icon "$XDG_DATA_HOME/icons/brightness.png" \
    -h string:synchronous:brightness-change
